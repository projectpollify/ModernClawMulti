{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "ModernClaw",
  "version": "0.1.0",
  "identifier": "com.localai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ModernClaw",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:11434"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "app",
      "dmg",
      "deb",
      "rpm",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "publisher": "ModernClaw",
    "shortDescription": "Private, offline brain creator for local AI agents",
    "longDescription": "A local-first desktop application for building private AI brains with memory, knowledge, voice, and offline-capable model management through Ollama.",
    "category": "Productivity",
    "copyright": "© 2026 ModernClaw",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}







